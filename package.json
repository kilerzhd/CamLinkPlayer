{
  "name": "camlink-player",
  "version": "1.1.0",
  "description": "A low latency video player for game capture devices.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.camlinkplayer.app",
    "productName": "CamLink Player",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "installer"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "en_US",
        "fr_FR"
      ]
    }
  },
  "author": {
    "name": "kilerzhd",
    "email": "kilerzhd@gmail.com"
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
